# Supabase — copy this file to `.env.local` and fill in the values.
#
# Both vars are safe to expose to the browser: they are protected by Row Level
# Security. The `NEXT_PUBLIC_` prefix is required so Next.js inlines them into
# the client bundle.

# --- Local development (default) ---
# Run `pnpm db:start` and these are the values it prints. The URL is fixed; the
# anon key is the standard local key (same on every machine — not a secret).
# Confirm both with `pnpm db:status` if a newer CLI prints different values.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0

# --- Hosted project ---
# From your project's API settings (https://supabase.com/dashboard →
# Project Settings → API). Swap these in to point at the cloud instead.
# NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

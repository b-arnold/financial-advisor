# Supabase — copy this file to `.env.local` and fill in the values from your
# project's API settings (https://supabase.com/dashboard → Project Settings → API).
#
# Both are safe to expose to the browser: they are protected by Row Level
# Security. The `NEXT_PUBLIC_` prefix is required so Next.js inlines them into
# the client bundle.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
